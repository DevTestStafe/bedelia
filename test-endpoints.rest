### ⚙️ CONFIGURACIÓN
# URL de Railway
@baseUrl = https://bedelia-production.up.railway.app

# Reemplaza con tu token Firebase (obtén con: python get_firebase_token.py testuser@example.com password)
@token = YOUR_TOKEN_HERE

###########################################################
# ENDPOINTS PÚBLICOS (Sin autenticación)
###########################################################

### 1. Health Check - Básico
GET {{baseUrl}}/healthz HTTP/1.1

###

### 2. Health Check - Detallado
GET {{baseUrl}}/api/health HTTP/1.1

###

### 3. Información de la API
GET {{baseUrl}}/ HTTP/1.1

###########################################################
# ENDPOINTS AUTENTICADOS (Requieren Bearer Token)
###########################################################

### 4. Obtener datos del usuario autenticado
GET {{baseUrl}}/api/auth/me HTTP/1.1
Authorization: Bearer {{token}}

###

### 5. Módulo Alumnos - Resumen
GET {{baseUrl}}/api/modulos/alumnos/summary HTTP/1.1
Authorization: Bearer {{token}}

###

### 6. Módulo Profesores - Resumen  
GET {{baseUrl}}/api/modulos/profesores/summary HTTP/1.1
Authorization: Bearer {{token}}

###

### 7. Módulo Empleados - Resumen
GET {{baseUrl}}/api/modulos/empleados/summary HTTP/1.1
Authorization: Bearer {{token}}

###

### 8. Módulo Materias - Resumen
GET {{baseUrl}}/api/modulos/materias/summary HTTP/1.1
Authorization: Bearer {{token}}

###

### 9. Módulo Jefatura - Resumen
GET {{baseUrl}}/api/modulos/jefatura/summary HTTP/1.1
Authorization: Bearer {{token}}

###########################################################
# PRUEBAS DE ERROR (Verificar manejo de errores)
###########################################################

### 10. Sin token (debe devolver 401)
GET {{baseUrl}}/api/auth/me HTTP/1.1

###

### 11. Con token inválido (debe devolver 401)
GET {{baseUrl}}/api/auth/me HTTP/1.1
Authorization: Bearer invalid_token_12345

###

### 12. Endpoint que no existe (debe devolver 404)
GET {{baseUrl}}/api/endpoint/inexistente HTTP/1.1
Authorization: Bearer {{token}}
